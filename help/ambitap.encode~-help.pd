#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.encode~ <order>;
#X text 20 32 Encode a mono source to higher-order ambisonics (point source).;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 200 ambitap.encode~ 3;
#X obj 40 300 ambitap.binaural~ 3;
#X obj 40 360 dac~;
#X floatatom 340 120 5 0 0 0 - - - 0;
#X msg 340 144 azimuth $1;
#X text 400 122 azimuth (deg);
#X msg 340 200 elevation 30;
#X msg 340 240 gain 1;
#X text 200 203 outlet: (order+1)^2 HOA channels (multichannel);
#X text 200 303 headphone monitor (binaural);
#X text 340 300 messages: azimuth / elevation / gain;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 6 1 7 1;
#X connect 8 0 9 0;
#X connect 9 0 5 0;
#X connect 11 0 5 0;
#X connect 12 0 5 0;
