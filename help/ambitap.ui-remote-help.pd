#N canvas 60 60 860 640 12;
#X text 20 10 ambitap.ui-remote — drive ambitap.*~ from the browser widgets;
#X text 20 34 1. In the AmbiTap library repo: cd ui && npm install && npm run build \, then serve dist/web/ over http and open index.html?remote=ws://localhost:8090;
#X text 20 78 2. Run the bridge: node ui/scripts/osc-bridge.mjs --listen 8090 --send 127.0.0.1:7500;
#X text 20 104 3. Open this patch and enable DSP. Dragging the browser panner moves source 1 \; tumbling the rotation ball rotates the field. Angles travel as radians end to end.;
#X obj 20 170 ambitap.ui-remote 7500;
#X obj 20 240 noise~;
#X obj 20 270 *~ 0.15;
#X obj 20 310 ambitap.encode~ 3;
#X obj 240 240 osc~ 440;
#X obj 240 270 *~ 0.1;
#X obj 240 310 ambitap.encode~ 3;
#X obj 20 360 +~;
#X obj 20 400 ambitap.rotate~ 3;
#X obj 20 440 ambitap.binaural~ 3;
#X obj 20 480 *~ 0.5;
#X obj 90 480 *~ 0.5;
#X obj 20 520 dac~;
#X text 200 172 outlets: source 1 \, source 2 \, orientation;
#X text 150 402 <- rotation ball / OSC head-tracking;
#X text 190 442 headphone monitor;
#X obj 20 580 declare -lib ambitap;
#X text 20 606 The browser side runs the verified WASM analysis (heatmap \, DOA \, meters) locally \; this patch receives only the control gestures.;
