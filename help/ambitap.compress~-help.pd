#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.compress~ <order>;
#X text 20 32 Spatial compressor: detector keys off W, one gain applied to all channels.;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 noise~;
#X obj 40 180 ambitap.encode~ 3;
#X obj 40 250 ambitap.compress~ 3;
#X obj 40 330 ambitap.binaural~ 3;
#X obj 40 390 dac~;
#X floatatom 340 120 5 0 0 0 - - - 0;
#X msg 340 144 threshold $1;
#X text 400 122 threshold (dB);
#X msg 340 200 ratio 4;
#X msg 340 240 attack 10;
#X msg 340 280 release 100;
#X msg 340 320 makeup_gain 6;
#X text 200 253 image-preserving HOA compression;
#X text 340 360 messages: threshold ratio attack release makeup_gain;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 7 1 8 1;
#X connect 9 0 10 0;
#X connect 10 0 6 0;
#X connect 12 0 6 0;
#X connect 13 0 6 0;
#X connect 14 0 6 0;
#X connect 15 0 6 0;
