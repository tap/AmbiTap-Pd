#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.distance~ <order>;
#X text 20 32 Distance cues on a HOA bus: Doppler delay, 1/r gain, air absorption, NFC.;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 180 ambitap.encode~ 3;
#X obj 40 250 ambitap.distance~ 3;
#X obj 40 330 ambitap.binaural~ 3;
#X obj 40 390 dac~;
#X floatatom 340 120 5 0 0 0 - - - 0;
#X msg 340 144 distance $1;
#X text 400 122 distance (m);
#X msg 340 200 reference_distance 1;
#X msg 340 236 attenuation 1;
#X msg 340 272 air_absorption 0.5;
#X msg 340 308 speed_of_sound 343;
#X msg 340 344 max_distance 50;
#X msg 340 384 doppler 1;
#X msg 420 384 doppler 0;
#X msg 340 420 nfc 1;
#X msg 420 420 nfc 0;
#X text 200 253 HOA in -> HOA out with distance cues;
#X text 40 430 sweep distance for a moving-source Doppler glide;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 7 1 8 1;
#X connect 9 0 10 0;
#X connect 10 0 6 0;
#X connect 12 0 6 0;
#X connect 13 0 6 0;
#X connect 14 0 6 0;
#X connect 15 0 6 0;
#X connect 16 0 6 0;
#X connect 17 0 6 0;
#X connect 18 0 6 0;
#X connect 19 0 6 0;
#X connect 20 0 6 0;
