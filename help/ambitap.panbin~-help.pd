#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.panbin~;
#X text 20 32 Direct per-source binaural panner (per-source HRTF, no ambisonic bus).;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 250 ambitap.panbin~;
#X obj 40 330 dac~;
#X floatatom 340 120 5 0 0 0 - - - 0;
#X msg 340 144 azimuth $1;
#X text 400 122 azimuth (rad \, pi/2 = left);
#X msg 340 200 elevation 0;
#X msg 340 240 gain 1;
#X text 200 253 mono in -> left / right (direction crossfades click-free);
#X text 340 290 messages: azimuth / elevation / gain;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 5 1 6 1;
#X connect 7 0 8 0;
#X connect 8 0 5 0;
#X connect 10 0 5 0;
#X connect 11 0 5 0;
