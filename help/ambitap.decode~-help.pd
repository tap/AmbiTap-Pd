#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.decode~ <order> <layout>;
#X text 20 32 Decode a HOA bus to a loudspeaker layout.;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 180 ambitap.encode~ 3;
#X obj 40 250 ambitap.decode~ 3 quad;
#X msg 340 130 decoder_type mode_match;
#X msg 340 165 decoder_type allrad;
#X msg 340 200 decoder_type epad;
#X msg 340 245 max_re 1;
#X msg 420 245 max_re 0;
#X text 200 253 outlet: speaker feeds (multichannel);
#X text 40 300 for N>2 speakers monitor with [dac~ 1 2 3 4 ...];
#X text 40 330 layouts: stereo quad surround_5_1 surround_7_1 surround_7_1_4 cube hexagon octagon;
#X text 40 350 5.1 / 7.1 / 7.1.4 are also accepted as layout names;
#X text 340 100 decoder_type:;
#X text 340 285 max_re weighting on / off;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 7 0 6 0;
#X connect 8 0 6 0;
#X connect 9 0 6 0;
#X connect 10 0 6 0;
#X connect 11 0 6 0;
