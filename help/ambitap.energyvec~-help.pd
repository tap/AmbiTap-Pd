#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.energyvec~;
#X text 20 32 Active-intensity DOA: x / y / z energy vector from the first 4 HOA channels.;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 180 ambitap.encode~ 1;
#X obj 40 250 ambitap.energyvec~;
#X msg 330 110 1;
#X msg 360 110 0;
#X obj 330 150 metro 50;
#X obj 330 210 snapshot~;
#X floatatom 330 250 5 0 0 0 - - - 0;
#X text 330 285 x;
#X obj 420 210 snapshot~;
#X floatatom 420 250 5 0 0 0 - - - 0;
#X text 420 285 y;
#X obj 510 210 snapshot~;
#X floatatom 510 250 5 0 0 0 - - - 0;
#X text 510 285 z;
#X msg 40 320 smoothing_time 50;
#X text 200 253 3 signal outlets: x / y / z;
#X text 330 90 click 1 to poll the vector:;
#X text 40 350 smoothing_time sets the averaging window (ms);
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 7 0 9 0;
#X connect 8 0 9 0;
#X connect 6 0 10 0;
#X connect 9 0 10 0;
#X connect 10 0 11 0;
#X connect 6 1 13 0;
#X connect 9 0 13 0;
#X connect 13 0 14 0;
#X connect 6 2 16 0;
#X connect 9 0 16 0;
#X connect 16 0 17 0;
#X connect 19 0 6 0;
