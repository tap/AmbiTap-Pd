#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.mirror~ <order>;
#X text 20 32 Mirror a HOA bus across cardinal planes (left-right / front-back / up-down).;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 180 ambitap.encode~ 3;
#X obj 40 250 ambitap.mirror~ 3;
#X obj 40 330 ambitap.binaural~ 3;
#X obj 40 390 dac~;
#X msg 340 130 flip_lr 1;
#X msg 420 130 flip_lr 0;
#X msg 340 170 flip_fb 1;
#X msg 420 170 flip_fb 0;
#X msg 340 210 flip_ud 1;
#X msg 420 210 flip_ud 0;
#X text 200 253 HOA in -> mirrored HOA out;
#X text 340 100 sign-flip toggles (1 = on, 0 = off):;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 7 1 8 1;
#X connect 9 0 6 0;
#X connect 10 0 6 0;
#X connect 11 0 6 0;
#X connect 12 0 6 0;
#X connect 13 0 6 0;
#X connect 14 0 6 0;
