#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.xtc~;
#X text 20 32 Transaural crosstalk cancellation: binaural/stereo over two loudspeakers.;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 170 ambitap.encode~ 3;
#X obj 40 240 ambitap.binaural~ 3;
#X obj 40 320 ambitap.xtc~;
#X obj 40 390 dac~;
#X floatatom 340 120 5 0 0 0 - - - 0;
#X msg 340 144 span $1;
#X text 400 122 speaker span (deg);
#X msg 340 200 distance 1;
#X msg 340 240 regularization 0.5;
#X msg 340 284 bypass 1;
#X msg 420 284 bypass 0;
#X text 200 323 left / right LOUDSPEAKER feeds (not headphones);
#X text 340 300 bypass = A/B reference (loudness-match upstream);
#X text 40 430 512-sample filter latency; ~-12 dB makeup on the cancelled path;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 6 1 7 1;
#X connect 7 0 8 0;
#X connect 7 1 8 1;
#X connect 9 0 10 0;
#X connect 10 0 7 0;
#X connect 12 0 7 0;
#X connect 13 0 7 0;
#X connect 14 0 7 0;
#X connect 15 0 7 0;
