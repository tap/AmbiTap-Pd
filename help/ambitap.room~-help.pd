#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.room~ <order>;
#X text 20 32 Shoebox room on a HOA bus: image-source early reflections + FDN tail.;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 250 ambitap.room~ 3;
#X obj 40 330 ambitap.binaural~ 3;
#X obj 40 390 dac~;
#X floatatom 340 120 5 0 0 0 - - - 0;
#X msg 340 144 rt60 $1;
#X text 400 122 RT60 (s);
#X msg 340 200 dim_x 7;
#X msg 340 236 dim_y 5;
#X msg 340 272 dim_z 3;
#X msg 340 312 direct 1;
#X msg 420 312 direct 0;
#X msg 340 348 er 1;
#X msg 420 348 er 0;
#X msg 340 384 tail 1;
#X msg 420 384 tail 0;
#X text 200 253 mono in -> (order+1)^2 HOA channels (wet room);
#X text 40 430 also: source_x/y/z, listener_x/y/z, gain, rt60band <hz> <s>, reflections <x0 x1 y0 y1 z0 z1>;
#X text 40 450 note: ~53 ms fixed latency at 48 kHz on every path;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 6 1 7 1;
#X connect 8 0 9 0;
#X connect 9 0 5 0;
#X connect 11 0 5 0;
#X connect 12 0 5 0;
#X connect 13 0 5 0;
#X connect 14 0 5 0;
#X connect 15 0 5 0;
#X connect 16 0 5 0;
#X connect 17 0 5 0;
#X connect 18 0 5 0;
#X connect 19 0 5 0;
