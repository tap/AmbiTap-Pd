#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.bed2hoa~ <order> <layout>;
#X text 20 32 Encode a channel-based surround bed to HOA (each speaker feed at its canonical direction).;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 170 ambitap.encode~ 3;
#X obj 40 230 ambitap.decode~ 3 quad;
#X obj 40 290 ambitap.bed2hoa~ 3 quad;
#X obj 40 360 ambitap.binaural~ 3;
#X obj 40 420 dac~;
#X msg 340 130 gain 1;
#X text 230 233 quad speaker feeds (a demo bed);
#X text 230 293 bed -> (order+1)^2 HOA channels;
#X text 40 460 feed real speaker channels in layout order (no LFE); layouts match ambitap.decode~;
#X text 340 100 message: gain;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 8 0 9 0;
#X connect 8 1 9 1;
#X connect 10 0 7 0;
