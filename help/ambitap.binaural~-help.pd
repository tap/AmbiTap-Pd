#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.binaural~ <order>;
#X text 20 32 Decode a HOA bus to binaural stereo (built-in MIT KEMAR, orders 1-5).;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 180 ambitap.encode~ 3;
#X obj 40 260 ambitap.binaural~ 3;
#X obj 40 330 dac~;
#X floatatom 340 120 5 0 0 0 - - - 0;
#X msg 340 144 yaw $1;
#X text 400 122 head yaw (rad);
#X msg 340 200 pitch 0;
#X msg 340 240 roll 0;
#X msg 340 280 volume 1;
#X msg 340 320 hrtf_dataset ls;
#X msg 460 320 hrtf_dataset magls;
#X text 200 263 left / right headphone outs;
#X text 340 300 HRTF projection:;
#X text 340 360 head-tracking: yaw / pitch / roll;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 6 1 7 1;
#X connect 8 0 9 0;
#X connect 9 0 6 0;
#X connect 11 0 6 0;
#X connect 12 0 6 0;
#X connect 13 0 6 0;
#X connect 14 0 6 0;
#X connect 15 0 6 0;
