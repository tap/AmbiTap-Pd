#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.doppler~ <order>;
#X text 20 32 Variable propagation delay on a HOA bus (modulate distance for Doppler).;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 180 ambitap.encode~ 3;
#X obj 40 250 ambitap.doppler~ 3;
#X obj 40 330 ambitap.binaural~ 3;
#X obj 40 390 dac~;
#X floatatom 340 120 5 0 0 0 - - - 0;
#X msg 340 144 distance $1;
#X text 400 122 distance (m);
#X msg 340 200 speed_of_sound 343;
#X msg 340 240 max_distance 100;
#X text 200 253 HOA in -> delayed HOA out;
#X text 340 290 sweep distance for a moving-source Doppler shift;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 7 1 8 1;
#X connect 9 0 10 0;
#X connect 10 0 6 0;
#X connect 12 0 6 0;
#X connect 13 0 6 0;
