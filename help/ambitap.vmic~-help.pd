#X obj 40 110 osc~ 220;
#X obj 40 180 ambitap.encode~ 3;
#X obj 40 250 ambitap.vmic~ 3;
#X obj 40 330 dac~;
#X floatatom 340 120 5 0 0 0 - - - 0;
#X msg 340 144 azimuth $1;
#X text 400 122 look azimuth (rad);
#X msg 340 200 elevation 0;
#X msg 340 240 max_re 1;
#X msg 420 240 max_re 0;
#X text 200 253 mono directional output;
#X text 340 280 max_re weighting on / off;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 6 0 7 1;
#X connect 8 0 9 0;
#X connect 9 0 6 0;
