#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.rotate~ <order>;
#X text 20 32 Rotate a HOA bus by yaw / pitch / roll (Euler Z-Y-X degrees).;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 180 ambitap.encode~ 3;
#X obj 40 250 ambitap.rotate~ 3;
#X obj 40 330 ambitap.binaural~ 3;
#X obj 40 390 dac~;
#X floatatom 340 120 5 0 0 0 - - - 0;
#X msg 340 144 yaw $1;
#X text 400 122 yaw (deg);
#X msg 340 200 pitch 0;
#X msg 340 240 roll 0;
#X text 200 253 HOA in -> HOA out (same order);
#X text 340 300 messages: yaw / pitch / roll;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 7 1 8 1;
#X connect 9 0 10 0;
#X connect 10 0 6 0;
#X connect 12 0 6 0;
#X connect 13 0 6 0;
