#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.format~ <order>;
#X text 20 32 Convert an ambisonics bus between FuMa and AmbiX (orders 0-3).;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 170 ambitap.encode~ 3;
#X obj 40 230 ambitap.format~ 3;
#X obj 40 290 ambitap.format~ 3;
#X obj 40 360 ambitap.binaural~ 3;
#X obj 40 420 dac~;
#X msg 340 130 direction ambix_to_fuma;
#X msg 340 170 direction fuma_to_ambix;
#X text 230 233 AmbiX -> FuMa;
#X text 230 293 FuMa -> AmbiX (round-trip back to AmbiX for monitoring);
#X text 340 100 direction:;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 8 0 9 0;
#X connect 8 1 9 1;
#X connect 10 0 6 0;
#X connect 11 0 7 0;
