#N canvas 40 40 660 540 12;
#X text 20 14 ambitap.directional~ <order>;
#X text 20 32 Per-direction gain on a HOA bus (1 = bypass, >1 boost, <1 attenuate).;
#X text 20 50 AmbiX convention: ACN channel ordering + SN3D normalization.;
#X obj 20 506 declare -lib ambitap;
#X obj 40 110 osc~ 220;
#X obj 40 180 ambitap.encode~ 3;
#X obj 40 250 ambitap.directional~ 3;
#X obj 40 330 ambitap.binaural~ 3;
#X obj 40 390 dac~;
#X floatatom 340 120 5 0 0 0 - - - 0;
#X msg 340 144 gain $1;
#X text 400 122 gain (linear);
#X msg 340 200 azimuth 1.57;
#X msg 340 240 elevation 0;
#X text 200 253 HOA in -> shaped HOA out;
#X text 340 290 messages: gain / azimuth / elevation;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 7 1 8 1;
#X connect 9 0 10 0;
#X connect 10 0 6 0;
#X connect 12 0 6 0;
#X connect 13 0 6 0;
