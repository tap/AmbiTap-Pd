#N canvas 40 40 900 640 12;
#X text 20 12 Hearing in Three Dimensions - 01 - First sounds (Pd edition);
#X text 20 34 A mono source orbits your head. Headphones on \, DSP on \, volume low. (Book: chapters 3 and 18.);
#X obj 20 600 declare -lib ambitap;
#X obj 40 110 noise~;
#X obj 40 146 *~ 0.25;
#X obj 40 260 ambitap.encode~ 3;
#X obj 40 380 ambitap.binaural~ 3;
#X obj 40 450 dac~;
#X floatatom 420 110 5 0 0 0 - - - 0;
#X obj 420 146 / 57.29578;
#X msg 420 180 azimuth $1;
#X text 480 112 azimuth in degrees (90 = left \, 180 = behind) - the / 57.3 converts to radians;
#X floatatom 420 230 5 0 0 0 - - - 0;
#X obj 420 266 / 57.29578;
#X msg 420 300 elevation $1;
#X text 480 232 elevation in degrees (90 = zenith);
#X msg 640 110 1;
#X msg 680 110 0;
#X obj 640 146 metro 30;
#X obj 640 190 phasor~ 0.05;
#X obj 640 226 snapshot~;
#X obj 640 262 * 6.2831853;
#X msg 640 296 azimuth $1;
#X text 720 112 orbit on / off (one revolution every 20 s);
#X text 40 286 one multichannel cord: 16 HOA channels (order 3);
#X text 40 406 scene -> your two ears (built-in KEMAR HRTFs);
#X text 40 520 Behind and above are places stereo cannot reach (book \, chapter 1). If elevation feels vague \, that is normal - the rendering uses a standard mannequin's ears \, not yours (chapter 13).;
