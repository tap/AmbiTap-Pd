#N canvas 60 60 760 560 12;
#X text 20 10 ambitap.ui-remote <udp-port>;
#X text 20 30 OSC remote surface for the AmbiTap UI widgets (library repo ui/): the browser dashboard mirrors panner and rotation-ball gestures as binary OSC over WebSocket \, ui/scripts/osc-bridge.mjs relays them to UDP \, and this abstraction routes them to the ambitap.*~ objects. Vanilla Pd >= 0.46 (netreceive -u -b + oscparse).;
#X text 20 110 Address space (angles in RADIANS \, the ambitap convention):;
#X text 40 130 /ambitap/source/<id>/direction <azimuth> <elevation>;
#X text 40 148 /ambitap/orientation <yaw> <pitch> <roll>;
#X text 20 178 Outlets: source 1 messages \, source 2 messages \, orientation messages — connect to ambitap.encode~ / ambitap.rotate~ (or binaural~) left inlets.;
#X obj 20 240 netreceive -u -b \$1;
#X obj 20 268 oscparse;
#X obj 20 296 list trim;
#X obj 20 324 route ambitap;
#X obj 20 352 route source orientation;
#X obj 20 380 route dummy1;
#X obj 20 408 route direction;
#X obj 20 436 unpack 0 0;
#X msg 20 464 azimuth \$1;
#X msg 100 464 elevation \$1;
#X obj 20 520 outlet;
#X obj 240 394 route dummy2;
#X obj 240 422 route direction;
#X obj 240 450 unpack 0 0;
#X msg 240 478 azimuth \$1;
#X msg 320 478 elevation \$1;
#X obj 240 520 outlet;
#X obj 460 380 unpack 0 0 0;
#X msg 460 408 yaw \$1;
#X msg 530 408 pitch \$1;
#X msg 600 408 roll \$1;
#X obj 460 520 outlet;
#X obj 460 240 loadbang;
#X msg 460 268 1;
#X obj 460 296 makefilename %d;
#X msg 540 268 2;
#X obj 540 296 makefilename %d;
#X text 460 200 oscparse emits path elements as SYMBOLS \, so the source ids are symbol "1"/"2" — untypeable as route args \; loadbang sets them via makefilename %d.;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
